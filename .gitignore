# Build outputs
**/bin/
**/obj/
**/publish/

# .NET
*.user
*.suo

# Local environment overrides (the shipped .env has defaults)
.env.local

# Artifacts (downloaded at runtime)
artifacts/

# IDE
.vs/
.vscode/
*.code-workspace

# AL development
.alpackages/
.dev/

# TestRunner WebSocket client (deprecated)
tools/TestRunner/lib/

# Local investigation snapshots (raw logs etc. preserved for reference,
# not for the repo). See MICROSOFT-FEEDBACK.md investigation log for what
# lives in here.
.snapshots/
extensions/minimal-test/*.app

# Local-only docker overrides (session/environment-specific, e.g. TLS-inspecting
# proxy CA injection for sandboxed build environments)
docker-compose.override.yml
.local-ca/
src/Dockerfile.local-ca
